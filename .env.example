# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (test mode keys for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=
EMAIL_FROM="Vzpomínkář <ahoj@vzpominkar.cz>"
EMAIL_REPLY_TO="ahoj@vzpominkar.cz"
# Optional: inbox that receives lead-magnet notifications. Falls back to EMAIL_FROM.
LEADS_NOTIFY_TO=

# OpenAI — Whisper transcription + gpt-4o-mini polish / year extraction
OPENAI_API_KEY=

# Upstash Redis / Vercel KV — rate limiting (auth + AI-cost caps).
# Provisioned via the Vercel marketplace integration (KV_* naming).
# Without these in prod, auth rate limiting is disabled (fail-open) — see lib/rate-limit.ts.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=
# HMAC secret for the internal book-print page (/print/book/[token]). The render
# API mints a short-lived token; the print page (reachable without an auth
# cookie) verifies it. Required to render PDFs — generate with:
#   openssl rand -hex 32
PRINT_SIGNING_SECRET=

# Pricing (CZK, integer). Leave 0 for local dev → skips Stripe (book activates free).
# Production values: base 2890, add-on 1790, gift book 1099. The FIRST printed book
# is INCLUDED in base, so PRICE_BOOK_PRINT_CZK stays 0; revenue add-ons are below.
PRICE_BOOK_BASE_CZK=0
PRICE_BOOK_ADDON_CZK=0
PRICE_BOOK_PRINT_CZK=0
# Each ADDITIONAL printed copy (the first is free). Set once the printer quote is
# known (e.g. 799). A launch-only 30% discount applies when the extra copy is
# bought at the moment of purchase (EXTRA_COPY_LAUNCH_DISCOUNT_PCT, lib/stripe/server.ts).
PRICE_BOOK_PRINT_EXTRA_CZK=0
# Premium cover-colour surcharge (any colour other than the included brown+gold).
# Pure margin — same binding. Code default 99.
PRICE_BOOK_COVER_PREMIUM_CZK=99
# Gift wrapping + embossed dedication. Code default 290 (placeholder until fulfilment cost known).
PRICE_BOOK_GIFTWRAP_CZK=290
# Guest GIFT book (/kniha/sestavit) — TIERED. Standard = our curated questions;
# custom = once the buyer adds their own question. Code defaults 599 / 899; set 0
# here for the free path locally (no Stripe key needed). Production: 599 / 899.
PRICE_SHOP_BOOK_STANDARD_CZK=0
PRICE_SHOP_BOOK_CUSTOM_CZK=0
